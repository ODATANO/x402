# Allow `@eslint/js@10` to coexist with `eslint@^9`. The `@eslint/js@10`
# peer dependency on `eslint@^10` is `peerOptional`; the conflict only
# surfaces because `@sap/cds@9.9` ranges its `@eslint/js` peer as
# `^9 || ^10` and npm picks the highest match. Until `@sap/eslint-plugin-cds`
# follows eslint to v10, we accept the optional-peer warning and continue.
# Applies to both local `npm install` and CI `npm ci`.
legacy-peer-deps=true
